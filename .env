# ============================================================
# SwarmClaw — Environment Configuration / 环境配置
#
# This file is committed to Git. Put secrets in .env.local (gitignored).
# 此文件提交到 Git。密钥放在 .env.local（已被 gitignore）。
#
# All fields are optional — defaults work for local dev.
# 所有字段均为可选，默认值适用于本地开发。
# ============================================================

# ── Core Ports 核心端口 ──────────────────────────────────────
# HTTP server port / HTTP 服务端口
PORT=3456
# Server bind address / 服务监听地址（设为 0.0.0.0 允许外网访问）
HOSTNAME=0.0.0.0

# ── WebSocket ────────────────────────────────────────────────
# WebSocket server port (default: PORT+1) / WebSocket 服务端口
# WS_PORT=3457
# WebSocket server binding URL override / WebSocket 服务绑定地址覆盖
# Example: ws://0.0.0.0:3457/ws
# WS_URL=
# Client-side WebSocket URL override (for reverse proxy) / 客户端 WebSocket 地址覆盖
# 反向代理部署时设置此项，例如：wss://your-domain.com/ws
# NEXT_PUBLIC_WS_URL=

# ── Security 安全（首次运行自动生成）────────────────────────
# API access key / API 访问密钥（不设置则自动生成）
# ACCESS_KEY=
# Credential encryption secret / 凭证加密密钥（不设置则自动生成）
# CREDENTIAL_SECRET=

# ── Data Directories 数据目录 ────────────────────────────────
# All paths below have smart defaults — leave them commented out unless you need to override.
# 以下路径均有智能默认值——除非需要覆盖，否则保持注释即可。
# Root data directory / 数据根目录（默认：项目目录/data）
# SWARMCLAW_HOME=
# Storage directory / 存储目录（默认：SWARMCLAW_HOME/data 或 项目目录/data）
# DATA_DIR=
# Workspace directory / 工作目录（默认：~/.swarmclaw/workspace）
# WORKSPACE_DIR=
# Browser profiles directory / 浏览器配置目录（默认：~/.swarmclaw/browser-profiles）
# BROWSER_PROFILES_DIR=
# Upload directory / 上传目录（默认：DATA_DIR/uploads）
# SWARMCLAW_UPLOAD_DIR=

# ── CORS / Network 网络访问 ──────────────────────────────────
# Allowed origins, comma-separated (* for all) / 允许的来源，逗号分隔（* 允许所有）
# SWARMCLAW_ALLOWED_ORIGINS=
# Extension install origins / 扩展安装来源
# SWARMCLAW_EXTENSION_INSTALL_ORIGINS=
# Extra dev origins (comma-separated hosts) / 额外开发来源
# NEXT_ALLOWED_DEV_ORIGINS=

# ── Worker & Daemon 工作进程与守护进程 ───────────────────────
# Set to 1 for worker-only mode / 设为 1 启用仅工作进程模式
# SWARMCLAW_WORKER_ONLY=0
# Daemon autostart / 守护进程自动启动（默认启用）
# SWARMCLAW_DAEMON_AUTOSTART=
# Daemon background services / 守护进程后台服务
# SWARMCLAW_DAEMON_BACKGROUND_SERVICES=
# Daemon admin port / 守护进程管理端口
# SWARMCLAW_DAEMON_ADMIN_PORT=
# Daemon admin token / 守护进程管理令牌
# SWARMCLAW_DAEMON_ADMIN_TOKEN=

# ── OpenTelemetry 可观测性（可选）───────────────────────────
# OTEL_ENABLED=false
OTEL_SERVICE_NAME=swarmclaw
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=

# ── Speech / TTS 语音（可选）────────────────────────────────
# ElevenLabs API key / ElevenLabs API 密钥
# ELEVENLABS_API_KEY=
# ElevenLabs voice ID / ElevenLabs 语音 ID
# ELEVENLABS_VOICE=
# OpenAI STT API key override / OpenAI 语音转文字密钥覆盖
# SWARMCLAW_OPENAI_STT_API_KEY=
# OpenAI STT base URL / OpenAI 语音转文字基础 URL
# SWARMCLAW_OPENAI_STT_BASE_URL=https://api.openai.com/v1
# OpenAI STT model / OpenAI 语音转文字模型
# SWARMCLAW_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# ElevenLabs STT model / ElevenLabs 语音转文字模型
# SWARMCLAW_ELEVENLABS_STT_MODEL=scribe_v1

# ── AI Provider Keys 模型密钥（推荐通过 UI 配置）────────────
# RECOMMENDED: Add API keys via the web UI after launch.
# 推荐方式：启动后在 Web UI 中添加 API key。
# 以下环境变量仅作兼容兜底。
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_API_KEY=
# EXA_API_KEY=

# ── Extension & Skills 扩展与技能（可选）─────────────────────
# Extension failure threshold / 扩展失败阈值（默认 3）
# SWARMCLAW_EXTENSION_FAILURE_THRESHOLD=3
# ClawHub API URL / ClawHub API 地址
# CLAWHUB_API_URL=https://clawhub.ai/api/v1
# ClawHub download API URL / ClawHub 下载 API 地址
# CLAWHUB_DOWNLOAD_API_URL=https://wry-manatee-359.convex.site/api/v1
# OpenClaw state directory / OpenClaw 状态目录
# OPENCLAW_STATE_DIR=

# ── Advanced 高级设置（通常不需要修改）──────────────────────
# Debug mode / 调试模式
# SWARMCLAW_DEBUG=0
# Performance profiling / 性能分析
# SWARMCLAW_PERF=0
# Prompt profiling / 提示词分析
# SWARMCLAW_PROFILE_PROMPT=0
# Working state timeout (ms) / 工作状态超时（毫秒）
# SC_WORKING_STATE_TIMEOUT_MS=
# Classifier timeout (ms) / 分类器超时（毫秒）
# SC_CLASSIFIER_TIMEOUT_MS=
# Completeness check timeout (ms) / 完整性检查超时（毫秒）
# SC_COMPLETENESS_TIMEOUT_MS=
# CLI connection URL / CLI 连接地址
# SWARMCLAW_URL=http://localhost:3456
# SwarmFeed API URL / SwarmFeed API 地址
# SWARMFEED_API_URL=https://swarmfeed-api.onrender.com

#
